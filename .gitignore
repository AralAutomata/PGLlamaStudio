# =============================================================================
# PG Studio - Comprehensive .gitignore
# =============================================================================
# This file excludes files that should not be tracked in version control
# Generated from best practices for Next.js, Node.js, TypeScript projects
# =============================================================================

# -----------------------------------------------------------------------------
# NODE / NPM
# -----------------------------------------------------------------------------
# Dependencies
node_modules/

# Package lock files (use pnpm-lock.yaml or yarn.lock instead if preferred)
package-lock.json
npm-debug.log*
yarn-debug.log*
yarn-error.log*
yarn.lock
pnpm-lock.yaml

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# -----------------------------------------------------------------------------
# NEXT.JS
# -----------------------------------------------------------------------------
# Build output
.next/
out/
build/
dist/

# Production cache
.cache/
.turbo/

# TypeScript cache
*.tsbuildinfo
next-env.d.ts

# -----------------------------------------------------------------------------
# DENO (project was originally set up with Deno)
# -----------------------------------------------------------------------------
deno.lock
.deno/
deno.json

# -----------------------------------------------------------------------------
# DATABASE & DOCKER
# -----------------------------------------------------------------------------
# Docker volumes
docker-compose.override.yml
*.volume.yml

# Database dumps
*.sql.gz
*.dump
*.bak

# PostgreSQL data (if running locally outside Docker)
pgdata/

# -----------------------------------------------------------------------------
# IDE & EDITOR
# -----------------------------------------------------------------------------
# VS Code
.vscode/
*.code-workspace
!.vscode/extensions.json
!.vscode/settings.jsonc

# JetBrains (IntelliJ, WebStorm, etc.)
.idea/
*.iml
*.ipr
*.iws
.idea_modules/

# Sublime Text
*.sublime-*

# Vim
*.swp
*.swo
*~
.DS_Store

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc

# -----------------------------------------------------------------------------
# TESTING & COVERAGE
# -----------------------------------------------------------------------------
coverage/
.nyc_output/
coverage.json
*.lcov

# -----------------------------------------------------------------------------
# LOGS
# -----------------------------------------------------------------------------
*.log
logs/
*.log.*

# -----------------------------------------------------------------------------
# TEMPORARY FILES
# -----------------------------------------------------------------------------
tmp/
temp/
*.tmp
*.temp

# -----------------------------------------------------------------------------
# OS GENERATED
# -----------------------------------------------------------------------------
# macOS
.DS_Store
._*
.Spotlight-V100
.Trashes
.VolumeIcon.icns
.apdisk

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/

# Linux
.fuse_hidden*
.directory
.Trash-*
.nfs*

# -----------------------------------------------------------------------------
# SECRETS & CREDENTIALS
# -----------------------------------------------------------------------------
*.pem
*.key
*.crt
*.p12
*.pfx
*.jks
*.keystore
*.p8
*.staging
*.production
credentials.json
secrets/
*.secret

# -----------------------------------------------------------------------------
# LOCAL CONFIGURATION
# -----------------------------------------------------------------------------
local.json
config.local.json
appsettings.*.json

# -----------------------------------------------------------------------------
# CACHE FILES
# -----------------------------------------------------------------------------
.npm/
.eslintcache
.node_repl_history
*.tsbuildinfo
.next.zip

# -----------------------------------------------------------------------------
# CI/CD
# -----------------------------------------------------------------------------
.github/ISSUE_TEMPLATE/
.github/pull_request_template.md
!.github/

# -----------------------------------------------------------------------------
# DOCUMENTATION GENERATED
# -----------------------------------------------------------------------------
docs/_build/
docs/.doctrees/
site/

# -----------------------------------------------------------------------------
# MISCELLANEOUS
# -----------------------------------------------------------------------------
*.bak
*.backup
*.orig
*.rej
*.diff
*.patch
*.egg-info/
.pytest_cache/
.npm/
.eslintcache
.parcel-cache/
.svelte-kit/
.vercel/
.netlify/
